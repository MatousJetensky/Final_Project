<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:final_project.ViewModels"
             xmlns:models="clr-namespace:final_project.Models"
             x:Class="final_project.Views.FilmDetailView"
             x:DataType="vm:FilmDetailViewModel">

    <Grid RowDefinitions="Auto,*" Margin="20">

        <!-- Hlavička -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <Button Content="← Zpět"
                    Command="{Binding GoBackCommand}"
                    Background="Transparent"/>
            <TextBlock Text="{Binding Film.Title}"
                       FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding Film.Director}"
                       FontSize="14" Opacity="0.6"/>
            <TextBlock Text="{Binding Film.StatusName}"
                       FontSize="12" Opacity="0.5"/>
            <Button Content="✏ Upravit film"
                    Command="{Binding EditFilmCommand}"
                    Margin="0,4,0,0"
                    Background="Transparent"/>
        </StackPanel>

        <!-- Spodní část: seznam + formulář -->
        <Grid Grid.Row="1" ColumnDefinitions="*,300">

            <!-- Seznam recenzí -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Reviews}"
                     SelectedItem="{Binding SelectedReview, Mode=TwoWay}"
                     Margin="0,0,16,0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Review">
                        <Border Padding="10" Margin="0,4"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="#333333"
                                Background="#1e1e1e">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Author}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Rating}"
                                               Opacity="0.7"/>
                                    <TextBlock Text="/ 10"
                                               Opacity="0.4"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Content}"
                                           Opacity="0.6" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Formulář pro recenzi -->
            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Přidat / upravit recenzi"
                           FontWeight="SemiBold" FontSize="16"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Autor *"/>
                <TextBox Text="{Binding Author}" Watermark="Jméno autora"/>

                <TextBlock Text="Hodnocení (1–10) *"/>
                <TextBox Text="{Binding Rating}" Watermark="např. 8"/>

                <TextBlock Text="Text recenze"/>
                <TextBox Text="{Binding Content}"
                         Watermark="Napište recenzi..."
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           IsVisible="{Binding ErrorMessage,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button Content="Uložit"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>

                <Button Content="🗑 Smazat recenzi"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding SelectedReview,
                        Converter={x:Static ObjectConverters.IsNotNull}}"
                        Foreground="Red"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>

                <Button Content="Zrušit výběr"
                        Command="{Binding ClearFormCommand}"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>