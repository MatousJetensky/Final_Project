<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:final_project.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="900" d:DesignHeight="600"
        x:Class="final_project.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Filmotéka"
        Width="900" Height="600"
        MinWidth="700" MinHeight="450">

    <Window.Styles>
        <Style Selector="Button.active">
            <Setter Property="Background" Value="#1a4a8a"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1f5aa8"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="200,*">

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">

                <TextBlock Text="NAVIGACE"
                           FontSize="11"
                           Margin="16,0,16,8"
                           Opacity="0.5"
                           FontWeight="SemiBold" />

                <Button Content="Seznam filmů"
                        Command="{Binding ShowFilmListCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Background="Transparent"
                        BorderThickness="0" />

                <Separator Margin="16,8" />

                <TextBlock Text="PŘEHLED"
                           FontSize="11"
                           Margin="16,0,16,8"
                           Opacity="0.5"
                           FontWeight="SemiBold" />

                <Button Content="Plánuji"
                        Command="{Binding FilterByStatusCommand}"
                        CommandParameter="Plánuji"
                        Classes.active="{Binding IsPlanujActive}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" BorderThickness="0" />

                <Button Content="Koukám"
                        Command="{Binding FilterByStatusCommand}"
                        CommandParameter="Koukám"
                        Classes.active="{Binding IsKoukamActive}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" BorderThickness="0" />

                <Button Content="Dokoukáno"
                        Command="{Binding FilterByStatusCommand}"
                        CommandParameter="Dokoukáno"
                        Classes.active="{Binding IsDokoukanoActive}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" BorderThickness="0" />

                <Button Content="Zrušeno"
                        Command="{Binding FilterByStatusCommand}"
                        CommandParameter="Zrušeno"
                        Classes.active="{Binding IsZrusenoActive}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10" BorderThickness="0" />

            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}" />

    </Grid>
</Window>